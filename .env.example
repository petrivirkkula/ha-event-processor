# Home Assistant Event Processor - Environment Configuration

# ============================================================================
# MQTT Configuration
# ============================================================================
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=ha-event-processor
MQTT_TOPIC_PREFIX=homeassistant/
MQTT_RECONNECT_DELAY=5

# ============================================================================
# Database Configuration
# ============================================================================
# For SQLite (local development):
DATABASE_URL=sqlite:///./ha_events.db

# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@postgres.default.svc.cluster.local:5432/ha_events
DATABASE_POOL_SIZE=5

# ============================================================================
# Google Cloud Configuration
# ============================================================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_DATASET_ID=ha_events
GCP_TABLE_ID=events

# Path to GCP service account JSON file (only needed if not using default credentials)
# GCP_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

GCP_BATCH_SIZE=100
GCP_BATCH_TIMEOUT_SECONDS=300

# ============================================================================
# Processing Configuration
# ============================================================================
ENABLE_GCP_SYNC=true
EVENT_RETENTION_DAYS=30
MAX_RETRIES=3
RETRY_BACKOFF_FACTOR=2.0

# ============================================================================
# Server Configuration
# ============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=INFO

